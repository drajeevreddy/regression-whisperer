# Database (Neon Postgres) — required for data persistence
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/regression_whisperer?sslmode=require

# Demo branch for live demos (optional, used by seed script)
NEON_DEMO_URL=postgresql://user:password@ep-xxx-database/regression_whisperer_demo?sslmode=require

# Optional: Neon API key for branch management
NEON_API_KEY=neon_api_key_here

# LLM Provider Keys — TWO ways to provide these:
#
# Option A (BYOK): Enter keys in the /setup page. Stored in your browser's
#   localStorage, sent as x-byok-keys header. Never touches our servers.
#
# Option B (Server-side): Set env vars here for the GitHub Action → webhook flow.
#   The Action calls /api/webhook which uses these keys when no BYOK header is present.
#   At least one is needed for the automated pipeline to work.
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
CEREBRAS_API_KEY=

# GitHub — needed for posting PR comments
GITHUB_TOKEN=
